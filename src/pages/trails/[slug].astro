---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Map from '../../components/Map.astro';

export async function getStaticPaths() {
  const trails = await getCollection('trails');
  return trails.map(trail => ({
    params: { slug: trail.id.replace(/\.md$/, '') },
    props: { trail },
  }));
}

const { trail } = Astro.props;
const slug = trail.id.replace(/\.md$/, '');

const pin = [{
  slug,
  title: trail.data.title,
  summary: trail.data.summary,
  lat: trail.data.lat,
  lng: trail.data.lng,
}];

const focus = { lat: trail.data.lat, lng: trail.data.lng };

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatNumber(n: number) {
  return n.toLocaleString('en-US');
}

function starHTML(rating: number, max = 5) {
  return '★'.repeat(rating) + '☆'.repeat(max - rating);
}
---

<Base
  title={trail.data.title}
  description={trail.data.summary}
  ogType="article"
  ogImage={trail.data.hero_image}
>
  <div class="trail-hero">
    <Map trails={pin} focus={focus} height="55vh" interactive={false} />
  </div>

  <div class="card">
    <p class="eyebrow">
      <a href="/">Take a Hike</a>
      <span class="eyebrow-sep">·</span>
      {trail.data.region}
    </p>

    <h1 class="trail-title">{trail.data.title}</h1>
    <p class="trail-lede">{trail.data.summary}</p>

    <dl class="facts">
      <div class="fact">
        <dt>Hiked</dt>
        <dd>{formatDate(trail.data.date)}</dd>
      </div>
      {trail.data.distance_mi && (
        <div class="fact">
          <dt>Distance</dt>
          <dd>{trail.data.distance_mi} mi</dd>
        </div>
      )}
      {trail.data.elevation_ft && (
        <div class="fact">
          <dt>Elevation gain</dt>
          <dd>{formatNumber(trail.data.elevation_ft)} ft</dd>
        </div>
      )}
      {trail.data.stars && (
        <div class="fact">
          <dt>Rating</dt>
          <dd class="fact-stars" aria-label={`${trail.data.stars} of 5 stars`}>
            {starHTML(trail.data.stars)}
          </dd>
        </div>
      )}
    </dl>

    {trail.data.substack_url ? (
      <a
        href={trail.data.substack_url}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-button"
      >
        Read the full report on Substack →
      </a>
    ) : (
      <p class="cta-coming-soon">Report coming soon.</p>
    )}

    <p class="back-link"><a href="/">← All trails</a></p>
  </div>
</Base>

<style>
  .trail-hero {
    margin: 0 -1.5rem;
  }

  .card {
    max-width: 620px;
    margin: 0 auto;
    padding: 2.5rem 0 4rem;
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 1.25rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .eyebrow a {
    color: var(--ink-faint);
    text-decoration: none;
  }
  .eyebrow a:hover { color: var(--accent); }

  .eyebrow-sep { color: var(--rule); }

  .trail-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .trail-lede {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0 2rem;
    margin: 0 0 2.25rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .fact { display: flex; flex-direction: column; gap: 0.15rem; }

  .facts dt {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .facts dd {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
  }

  .fact-stars {
    color: var(--ink-faint);
    letter-spacing: 0.08em;
  }

  .cta-button {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    border-radius: 2px;
    margin-bottom: 2rem;
    transition: background-color 0.15s ease, transform 0.12s ease, box-shadow 0.12s ease;
    box-shadow: 0 2px 8px rgba(185, 68, 31, 0.25);
  }

  .cta-button:hover {
    background: var(--accent-deep);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(185, 68, 31, 0.35);
    color: #fff;
  }

  .cta-coming-soon {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--ink-faint);
    margin: 0 0 2rem;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--ink-faint);
    margin: 0;
  }

  .back-link a {
    color: var(--ink-faint);
    text-decoration: none;
  }
  .back-link a:hover { color: var(--accent); }

  @media (max-width: 600px) {
    .trail-hero { margin: 0 -1.5rem; }
  }
</style>
