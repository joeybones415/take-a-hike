---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Map from '../../components/Map.astro';

export async function getStaticPaths() {
  const trails = await getCollection('trails');
  return trails.map(trail => ({
    params: { slug: trail.id.replace(/\.md$/, '') },
    props: { trail },
  }));
}

const { trail } = Astro.props;
const { Content } = await render(trail);

const slug = trail.id.replace(/\.md$/, '');
const pin = [{
  slug,
  title: trail.data.title,
  summary: trail.data.summary,
  lat: trail.data.lat,
  lng: trail.data.lng,
}];

const focus = { lat: trail.data.lat, lng: trail.data.lng };

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatNumber(n: number) {
  return n.toLocaleString('en-US');
}

function starHTML(rating: number, max = 5) {
  return '★'.repeat(rating) + '☆'.repeat(max - rating);
}
---

<Base title={trail.data.title} description={trail.data.summary}>
  <Map trails={pin} focus={focus} height="38vh" interactive={false} />

  <article class="report">
    <p class="eyebrow">
      <a href="/">Take a Hike</a>
      <span class="eyebrow-sep">·</span>
      {trail.data.region}
    </p>

    <h1 class="report-title">{trail.data.title}</h1>
    <p class="report-lede">{trail.data.summary}</p>

    <dl class="facts">
      <div class="fact">
        <dt>Hiked</dt>
        <dd>{formatDate(trail.data.date)}</dd>
      </div>
      {trail.data.distance_mi && (
        <div class="fact">
          <dt>Distance</dt>
          <dd>{trail.data.distance_mi} mi</dd>
        </div>
      )}
      {trail.data.elevation_ft && (
        <div class="fact">
          <dt>Elevation gain</dt>
          <dd>{formatNumber(trail.data.elevation_ft)} ft</dd>
        </div>
      )}
      {trail.data.stars && (
        <div class="fact">
          <dt>Rating</dt>
          <dd class="fact-stars" aria-label={`${trail.data.stars} of 5 stars`}>
            {starHTML(trail.data.stars)}
          </dd>
        </div>
      )}
    </dl>

    <div class="prose">
      <Content />
    </div>

    <p class="back-link"><a href="/">← All trails</a></p>
  </article>
</Base>

<style>
  .report {
    max-width: 680px;
    margin: 0 auto;
    padding-top: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 1.25rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .eyebrow a {
    color: var(--ink-faint);
    text-decoration: none;
  }
  .eyebrow a:hover {
    color: var(--accent);
  }

  .eyebrow-sep {
    color: var(--rule);
  }

  .report-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .report-lede {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0 2rem;
    margin: 0 0 2rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .fact {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .facts dt {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .facts dd {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
  }

  .fact-stars {
    color: var(--ink-faint);
    letter-spacing: 0.08em;
  }

  .back-link {
    margin-top: 3rem;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--ink-faint);
  }

  .back-link a {
    color: var(--ink-faint);
    text-decoration: none;
  }

  .back-link a:hover {
    color: var(--accent);
  }
</style>
