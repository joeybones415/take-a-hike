---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Map from '../components/Map.astro';

const allTrails = await getCollection('trails');
allTrails.sort((a, b) => {
  const aTime = a.data.date?.getTime() ?? 0;
  const bTime = b.data.date?.getTime() ?? 0;
  return bTime - aTime;
});

const hikedTrails = allTrails.filter(t => (t.data.status ?? 'hiked') === 'hiked');
const staticPlannedTrails = allTrails.filter(t => t.data.status === 'planned');

const pins = allTrails.map(t => ({
  slug: t.id.replace(/\.md$/, ''),
  title: t.data.title,
  summary: t.data.summary,
  lat: t.data.lat,
  lng: t.data.lng,
  status: t.data.status ?? 'hiked',
  gpx: t.data.gpx,
  distance_mi: t.data.distance_mi,
  duration: t.data.duration,
  stars: t.data.stars,
  difficulty: t.data.difficulty,
  route_type: t.data.route_type,
}));
---

<Base title="Take a Hike" description="a personal map of my adventures.">
  <Map trails={pins} height="min(70vh, 640px)" showFab={true} />

  <p class="atlas-intro">
    <em>A personal map of my hikes that I have completed or have planned. Click a pin to see more details.</em>
  </p>

  <section class="index-list">
    <header class="list-head">
      <h2 class="list-title">The Reports</h2>
      <span class="trail-count" id="trail-count">
        {hikedTrails.length} hiked{staticPlannedTrails.length > 0 ? ` · ${staticPlannedTrails.length} planned` : ''}
      </span>
    </header>

    <ol class="trail-list">
      {hikedTrails.map((trail) => {
        const slug = trail.id.replace(/\.md$/, '');
        return (
          <li class="trail-row">
            <a href={`/trails/${slug}`} class="trail-link">
              <span class="trail-num" aria-hidden="true"></span>
              <div class="trail-body">
                <p class="trail-title">{trail.data.title}</p>
                <p class="trail-summary">{trail.data.summary}</p>
                <div class="trail-row-meta">
                  <span class="region">{trail.data.region}</span>

                  {(trail.data.distance_mi || trail.data.duration) && (
                    <span class="meta-divider" aria-hidden="true"></span>
                  )}

                  {(trail.data.distance_mi || trail.data.duration) && (
                    <span class="meta-group">
                      {trail.data.distance_mi && <span>{trail.data.distance_mi} mi</span>}
                      {trail.data.distance_mi && trail.data.duration && <span class="dot-sep">·</span>}
                      {trail.data.duration && <span>{trail.data.duration}</span>}
                    </span>
                  )}

                  {(trail.data.stars || trail.data.difficulty || trail.data.route_type) && (
                    <span class="meta-divider" aria-hidden="true"></span>
                  )}

                  {(trail.data.stars || trail.data.difficulty || trail.data.route_type) && (
                    <span class="meta-group">
                      {trail.data.stars && (
                        <span class="stars" aria-label={`${trail.data.stars} out of 5`}>
                          {'★'.repeat(trail.data.stars)}<span class="stars-empty">{'★'.repeat(5 - trail.data.stars)}</span>
                        </span>
                      )}
                      {trail.data.stars && (trail.data.difficulty || trail.data.route_type) && <span class="dot-sep">·</span>}
                      {trail.data.difficulty && (
                        <span class="difficulty-inline">
                          <span class={`difficulty-dot difficulty-${trail.data.difficulty}`} aria-hidden="true"></span>
                          {trail.data.difficulty.charAt(0).toUpperCase() + trail.data.difficulty.slice(1)}
                        </span>
                      )}
                      {trail.data.difficulty && trail.data.route_type && <span class="dot-sep">·</span>}
                      {trail.data.route_type && (
                        <span class="route-type-inline">
                          {trail.data.route_type === 'out-and-back' && (
                            <>
                              <svg class="route-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M3 12 L21 12"/><path d="M7 8 L3 12 L7 16"/><path d="M17 8 L21 12 L17 16"/>
                              </svg>
                              Out &amp; back
                            </>
                          )}
                          {trail.data.route_type === 'loop' && (
                            <>
                              <svg class="route-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M8 5 A 7 7 0 1 1 5 10"/><path d="M5 7 L5 11 L9 11"/>
                              </svg>
                              Loop
                            </>
                          )}
                          {trail.data.route_type === 'point-to-point' && (
                            <>
                              <svg class="route-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M3 12 L20 12"/><path d="M15 7 L20 12 L15 17"/>
                              </svg>
                              Point to point
                            </>
                          )}
                        </span>
                      )}
                    </span>
                  )}
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ol>

    <!-- Planned section: static from markdown + localStorage hikes injected by JS -->
    <div class="planned-section" id="planned-section" style={staticPlannedTrails.length === 0 ? 'display:none' : ''}>
      <div class="planned-section-head">
        <span class="planned-label">◌ Planned</span>
      </div>

      {staticPlannedTrails.map((trail) => {
        const slug = trail.id.replace(/\.md$/, '');
        return (
          <a href={`/trails/${slug}`} class="trail-link planned-row">
            <span class="planned-num" aria-hidden="true">—</span>
            <div class="trail-body">
              <p class="trail-title planned-title">{trail.data.title}</p>
              <p class="trail-summary">{trail.data.notes ?? trail.data.summary}</p>
              <div class="trail-row-meta">
                <span class="region">{trail.data.region}</span>
                {trail.data.difficulty && (
                  <>
                    <span class="meta-divider" aria-hidden="true"></span>
                    <span class="difficulty-inline">
                      <span class={`difficulty-dot difficulty-${trail.data.difficulty}`} aria-hidden="true"></span>
                      ~{trail.data.difficulty.charAt(0).toUpperCase() + trail.data.difficulty.slice(1)}
                    </span>
                  </>
                )}
              </div>
            </div>
          </a>
        );
      })}

      <!-- localStorage planned hikes injected here -->
      <div id="ls-planned-list"></div>
    </div>
  </section>
</Base>

<script>
  interface LsHike {
    id: string;
    status: 'planned' | 'hiked';
    title: string;
    lat: number;
    lng: number;
    notes?: string;
    distance_mi?: number;
    duration?: string;
    elevation_ft?: number;
    difficulty?: 'easy' | 'moderate' | 'hard';
    route_type?: 'out-and-back' | 'loop' | 'point-to-point';
    region?: string;
  }

  function difficultyLabel(d: string) {
    return d.charAt(0).toUpperCase() + d.slice(1);
  }

  function buildPlannedRow(hike: LsHike): string {
    const meta = [
      hike.region ? `<span class="region">${hike.region}</span>` : '',
      hike.difficulty
        ? `<span class="meta-divider" aria-hidden="true"></span>
           <span class="difficulty-inline">
             <span class="difficulty-dot difficulty-${hike.difficulty}" aria-hidden="true"></span>
             ~${difficultyLabel(hike.difficulty)}
           </span>`
        : '',
    ].filter(Boolean).join('');

    return `
      <a href="/plan?view=${hike.id}" class="trail-link planned-row ls-planned-row">
        <span class="planned-num" aria-hidden="true">—</span>
        <div class="trail-body">
          <p class="trail-title planned-title">${hike.title}</p>
          ${hike.notes ? `<p class="trail-summary">${hike.notes}</p>` : ''}
          <div class="trail-row-meta">${meta}</div>
        </div>
      </a>
    `;
  }

  try {
    const hikes: LsHike[] = JSON.parse(localStorage.getItem('tak-hikes') ?? '[]');
    const lsPlanned = hikes.filter(h => h.status === 'planned');

    if (lsPlanned.length > 0) {
      const section = document.getElementById('planned-section')!;
      const listEl = document.getElementById('ls-planned-list')!;
      section.style.display = '';
      listEl.innerHTML = lsPlanned.map(buildPlannedRow).join('');

      // Update count display
      const countEl = document.getElementById('trail-count');
      if (countEl) {
        const hikedMatch = countEl.textContent?.match(/(\d+) hiked/);
        const hikedN = hikedMatch ? parseInt(hikedMatch[1]) : 0;
        const staticPlannedMatch = countEl.textContent?.match(/· (\d+) planned/);
        const staticPlannedN = staticPlannedMatch ? parseInt(staticPlannedMatch[1]) : 0;
        const totalPlanned = staticPlannedN + lsPlanned.length;
        countEl.textContent = `${hikedN} hiked · ${totalPlanned} planned`;
      }
    }
  } catch (_) {}
</script>

<style>
  .index-list {
    margin-top: 3rem;
  }

  .list-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
  }

  .list-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--ink);
    margin: 0;
  }

  .trail-count {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .trail-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: trail;
  }

  .trail-row {
    counter-increment: trail;
    border-bottom: 1px solid var(--rule);
  }

  .trail-link {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0.5rem;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
    transition: background-color 0.12s ease;
  }

  .trail-link:hover {
    background-color: var(--paper-deep);
  }

  .trail-link:hover .trail-title {
    color: var(--accent);
  }

  .trail-num {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-faint);
    min-width: 2rem;
    text-align: right;
    padding-top: 0.2em;
    flex-shrink: 0;
  }

  .trail-num::before {
    content: counter(trail, decimal-leading-zero);
  }

  .trail-body {
    flex: 1;
    min-width: 0;
  }

  .trail-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--ink);
    margin: 0 0 0.3rem;
    transition: color 0.12s ease;
  }

  .trail-summary {
    font-family: var(--font-body);
    font-size: 0.925rem;
    color: var(--ink-soft);
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }

  .trail-row-meta {
    margin-top: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .meta-group {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }

  .meta-divider {
    display: inline-block;
    width: 1px;
    height: 14px;
    background: var(--rule);
    flex-shrink: 0;
  }

  .dot-sep {
    opacity: 0.6;
  }

  .region {
    color: var(--ink-soft);
    font-weight: 500;
  }

  .stars {
    color: var(--accent);
    letter-spacing: 0.03em;
  }
  .stars-empty {
    color: var(--rule);
  }

  .difficulty-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .difficulty-inline .difficulty-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }
  .difficulty-inline .difficulty-easy     { background: #5ba65a; }
  .difficulty-inline .difficulty-moderate { background: #d4a64a; }
  .difficulty-inline .difficulty-hard     { background: #c24a3a; }

  .route-type-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .route-type-inline .route-icon {
    color: var(--ink-soft);
    flex-shrink: 0;
  }

  .atlas-intro {
    margin: 1.75rem 0 0;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .atlas-intro em {
    font-style: italic;
  }

  /* Planned section */
  .planned-section {
    margin-top: 0;
    border-bottom: 1px solid var(--rule);
  }

  .planned-section-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0.5rem 0.6rem;
    border-top: 1px solid var(--rule);
  }

  .planned-label {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6c4aa8;
  }

  .planned-row {
    border-top: 1px solid var(--rule);
    border-bottom: none;
  }

  .planned-num {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-faint);
    min-width: 2rem;
    text-align: right;
    padding-top: 0.2em;
    flex-shrink: 0;
  }

  .planned-title {
    color: #6c4aa8;
  }

  .trail-link:hover .planned-title {
    color: #6c4aa8;
    opacity: 0.8;
  }
</style>
